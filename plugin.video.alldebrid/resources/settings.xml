<?xml version="1.0" encoding="UTF-8"?>
<settings>
    <category label="Account">
        <setting id="api_key" type="text" label="API Key" default="" option="hidden"/>
        <setting id="username" type="text" label="Logged in as" default="" enable="false"/>
        <setting id="premium_until" type="text" label="Premium until" default="" enable="false"/>
    </category>
    <category label="Playback">
        <setting id="preferred_quality" type="labelenum" label="Preferred Video Quality"
                 lvalues="Original (Direct Link)|1080p|720p|480p" default="0"/>
        <setting id="auto_play_single" type="bool" label="Auto-play single file magnets" default="true"/>
        <setting id="enable_resume" type="bool" label="Resume playback where you left off" default="true"/>
    </category>
    <category label="Library">
        <setting id="library_movies_path" type="text" label="Movies library path"
                 default="special://profile/strm/Movies"/>
        <setting id="library_tvshows_path" type="text" label="TV Shows library path"
                 default="special://profile/strm/TVShows"/>
        <setting id="auto_sync" type="bool" label="Auto-sync new magnets to library" default="false"/>
        <setting id="tmdb_api_key" type="text"
                 label="TMDB API Key  (get a free key at themoviedb.org/settings/api)"
                 default=""/>
    </category>
    <category label="Advanced">
        <setting id="debug_logging" type="bool" label="Enable debug logging" default="false"/>
    </category>
</settings>
